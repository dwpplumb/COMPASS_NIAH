# xAI/OpenAI-compatible chat endpoint
NIAH_LLM_ENDPOINT_URL=https://api.x.ai/v1/chat/completions
NIAH_LLM_API_KEY=
NIAH_LLM_MODEL=
NIAH_LLM_TIMEOUT_S=120
NIAH_LLM_TEMPERATURE=0.0

# Optional OpenAI-compatible embeddings endpoint
NIAH_EMBEDDINGS_PROVIDER=deterministic
NIAH_EMBEDDINGS_ENDPOINT_URL=
NIAH_EMBEDDINGS_API_KEY=
NIAH_EMBEDDINGS_MODEL=
NIAH_EMBEDDINGS_DIM=768
NIAH_EMBEDDINGS_TIMEOUT_S=60

# Postgres + pgvector for RAG mode
NIAH_PG_DSN=postgresql://user:password@localhost:5432/compass_niah

# Prompt/behavior
NIAH_COMPASS_PROMPT_FILE=
NIAH_SYSTEM_PROMPT=You are a precise assistant. Answer strictly from provided context.
NIAH_MAX_CONTEXT_TOKENS=1000000
NIAH_RAG_TOP_K=8
NIAH_RAG_CHUNK_CHARS=1200
NIAH_RAG_CHUNK_OVERLAP_CHARS=200

# Logging
NIAH_LOG_JSONL_PATH=logs/runs.jsonl
NIAH_PROMPT_IO_LOG_ENABLED=1
NIAH_PROMPT_IO_LOG_JSONL_PATH=logs/prompt_io.jsonl
